{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Cargo Build Debug",
            "type": "shell",
            "command": "source /home/lapsw1-2024/rust-env.sh && cargo build",
            "options": {
                "env": {
                    "PATH": "/home/lapsw1-2024/cargo-standalone/bin:${env:PATH}"
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$rustc"
            ]
        },
        {
            "label": "Cargo Build Release",
            "type": "shell",
            "command": "source /home/lapsw1-2024/rust-env.sh && cargo build --release",
            "options": {
                "env": {
                    "PATH": "/home/lapsw1-2024/cargo-standalone/bin:${env:PATH}"
                }
            },
            "group": "build",
            "problemMatcher": [
                "$rustc"
            ]
        }
    ]
}